{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkillBox",
  "version": "0.1.0-alpha.2",
  "identifier": "io.github.santosli.skillbox",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SkillBox",
        "hiddenTitle": true,
        "maximized": true,
        "width": 1120,
        "height": 760,
        "minWidth": 860,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
